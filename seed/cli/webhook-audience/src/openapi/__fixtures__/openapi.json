                "managed",
                "external"
              ],
              "x-fern-enum": {
                "all": {
                  "name": "All",
                  "description": "Every user, including external collaborators."
                },
                "managed": {
                  "name": "Managed",
                  "description": "Users your enterprise manages."
                },
                "external": {
                  "name": "External",
                  "description": "External collaborators only."
