-                    .ToArray();
-            }
-
-            type = type.BaseType;
-        }
-
-        throw new InvalidOperationException($"{type} isn't OneOf or OneOfBase");
-    }
-
-    public override bool CanConvert(global::System.Type typeToConvert)
-    {
-        return typeof(IOneOf).IsAssignableFrom(typeToConvert);
-    }
-}
