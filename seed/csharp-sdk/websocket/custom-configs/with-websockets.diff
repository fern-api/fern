+        Assert.That(info.Type, Is.EqualTo(DisconnectionType.ByServer));
+        Assert.That(info.CloseStatus, Is.EqualTo(WebSocketCloseStatus.NormalClosure));
+        Assert.That(info.CloseStatusDescription, Is.EqualTo("Normal closure"));
