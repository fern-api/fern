+
+    [Test]
+    public void AddString_ProducesQueryParam()
+    {
+        var query = new Query();
+        query.Add("key", "value");
+
+        Assert.That(query.ToString(), Is.EqualTo("key=value"));
+    }
+
+    [Test]
+    public void AddMultipleParams_JoinedWithAmpersand()
