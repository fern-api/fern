-@pytest.mark.parametrize("client", [SeedExhaustive(base_url="foo"), AsyncSeedExhaustive(base_url="foo")])
-def test_root_client_lazy_loading(client: Union[SeedExhaustive, AsyncSeedExhaustive]):
