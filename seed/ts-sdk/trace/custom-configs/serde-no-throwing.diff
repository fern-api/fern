+                    path: ["foo"],
+                    message: "Expected string. Received 123.",
+                },
+            ],
+        );
+    });
+
+    describe("json", () => {
+        itJson("includes unknown values", baseSchema.passthrough(), {
+            raw: {
+                foo: "hello",
+                bar: "bar",
+
+                baz: "extra",
+            },
+            parsed: {
+                foo: "hello",
+                bar: "bar",
+
+                baz: "extra",
