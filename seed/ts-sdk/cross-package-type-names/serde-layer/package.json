{
    "name": "@fern/cross-package-type-names",
    "version": "0.0.1",
    "private": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cross-package-type-names/fern.git"
    },
    "type": "commonjs",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.mjs",
    "types": "./dist/cjs/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/esm/index.d.mts",
                "default": "./dist/esm/index.mjs"
            },
            "require": {
                "types": "./dist/cjs/index.d.ts",
                "default": "./dist/cjs/index.js"
            },
            "default": "./dist/cjs/index.js"
        },
        "./serialization": {
            "import": {
                "types": "./dist/esm/serialization/index.d.mts",
                "default": "./dist/esm/serialization/index.mjs"
            },
            "require": {
                "types": "./dist/cjs/serialization/index.d.ts",
                "default": "./dist/cjs/serialization/index.js"
            },
            "default": "./dist/cjs/serialization/index.js"
        },
        "./folderA": {
            "import": {
                "types": "./dist/esm/api/resources/folderA/exports.d.mts",
                "default": "./dist/esm/api/resources/folderA/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/folderA/exports.d.ts",
                "default": "./dist/cjs/api/resources/folderA/exports.js"
            },
            "default": "./dist/cjs/api/resources/folderA/exports.js"
        },
        "./folderA/service": {
            "import": {
                "types": "./dist/esm/api/resources/folderA/resources/service/exports.d.mts",
                "default": "./dist/esm/api/resources/folderA/resources/service/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/folderA/resources/service/exports.d.ts",
                "default": "./dist/cjs/api/resources/folderA/resources/service/exports.js"
            },
            "default": "./dist/cjs/api/resources/folderA/resources/service/exports.js"
        },
        "./folderB": {
            "import": {
                "types": "./dist/esm/api/resources/folderB/exports.d.mts",
                "default": "./dist/esm/api/resources/folderB/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/folderB/exports.d.ts",
                "default": "./dist/cjs/api/resources/folderB/exports.js"
            },
            "default": "./dist/cjs/api/resources/folderB/exports.js"
        },
        "./folderC": {
            "import": {
                "types": "./dist/esm/api/resources/folderC/exports.d.mts",
                "default": "./dist/esm/api/resources/folderC/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/folderC/exports.d.ts",
                "default": "./dist/cjs/api/resources/folderC/exports.js"
            },
            "default": "./dist/cjs/api/resources/folderC/exports.js"
        },
        "./folderD": {
            "import": {
                "types": "./dist/esm/api/resources/folderD/exports.d.mts",
                "default": "./dist/esm/api/resources/folderD/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/folderD/exports.d.ts",
                "default": "./dist/cjs/api/resources/folderD/exports.js"
            },
            "default": "./dist/cjs/api/resources/folderD/exports.js"
        },
        "./folderD/service": {
            "import": {
                "types": "./dist/esm/api/resources/folderD/resources/service/exports.d.mts",
                "default": "./dist/esm/api/resources/folderD/resources/service/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/folderD/resources/service/exports.d.ts",
                "default": "./dist/cjs/api/resources/folderD/resources/service/exports.js"
            },
            "default": "./dist/cjs/api/resources/folderD/resources/service/exports.js"
        },
        "./foo": {
            "import": {
                "types": "./dist/esm/api/resources/foo/exports.d.mts",
                "default": "./dist/esm/api/resources/foo/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/foo/exports.d.ts",
                "default": "./dist/cjs/api/resources/foo/exports.js"
            },
            "default": "./dist/cjs/api/resources/foo/exports.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "reference.md",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "format": "biome format --write --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "format:check": "biome format --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint": "biome lint --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint:fix": "biome lint --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check": "biome check --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check:fix": "biome check --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "build": "pnpm build:cjs && pnpm build:esm",
        "build:cjs": "tsc --project ./tsconfig.cjs.json",
        "build:esm": "tsc --project ./tsconfig.esm.json && node scripts/rename-to-esm-files.js dist/esm",
        "test": "vitest",
        "test:unit": "vitest --project unit",
        "test:wire": "vitest --project wire"
    },
    "dependencies": {},
    "devDependencies": {
        "webpack": "^5.97.1",
        "ts-loader": "^9.5.1",
        "vitest": "^3.2.4",
        "msw": "2.11.2",
        "@types/node": "^18.19.70",
        "typescript": "~5.7.2",
        "@biomejs/biome": "2.4.3"
    },
    "browser": {
        "fs": false,
        "os": false,
        "path": false,
        "stream": false,
        "crypto": false
    },
    "packageManager": "pnpm@10.20.0",
    "engines": {
        "node": ">=18.0.0"
    },
    "sideEffects": false
}
