+    itValidate(
+        "unrecognized discriminant value",
+        union("type", {
+            lion: object({}),
+            tiger: object({ value: string() }),
+        }),
+        {
+            type: "bear",
+        },
+        [
+            {
+                path: ["type"],
+                message: 'Expected enum. Received "bear".',
+            },
+        ],
+    );
+});
diff --git a/tests/unit/schemas/utils/itSchema.ts b/tests/unit/schemas/utils/itSchema.ts
