+                skipValidation: true,
+            },
+        );
+
+        expect(parsed).toEqual({
+            ok: true,
+            value: {
+                camelCase: "hello",
+                numberProperty: "oops",
+                anyPrimitive: true,
+            },
+        });
+
+        expect(warningLogs).toEqual([
+            `Failed to validate.
+  - numberProperty: Expected number. Received "oops".`,
+        ]);
+
+        console.warn = originalConsoleWarn;
+    });
