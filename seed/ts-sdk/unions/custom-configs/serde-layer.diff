+export function booleanLiteral<V extends boolean>(literal: V): Schema<V, V> {
+    const schemaCreator = createIdentitySchemaCreator(
+        SchemaType.BOOLEAN_LITERAL,
+        (value, { breadcrumbsPrefix = [] } = {}) => {
+            if (value === literal) {
