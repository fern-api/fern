+                raw: { _type: "moose", isAMoose: true },
+                // @ts-expect-error
+                parsed: { type: "moose", isAMoose: true },
+                opts: {
+                    allowUnrecognizedUnionMembers: true,
+                },
+            },
+        );
+    });
+
+    describe("withParsedProperties", () => {
+        it("Added property is included on parsed object", async () => {
+            const schema = union("type", {
