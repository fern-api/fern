{
    "name": "@fern/simple-api",
    "version": "0.0.1",
    "private": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/simple-api/fern.git"
    },
    "license": "MIT",
    "files": [
        "dist",
        "types",
        "api/resources/user.d.ts"
    ],
    "exports": {
        ".": {
            "node": "./dist/node/index.js",
            "import": {
                "types": "./types/index.d.ts",
                "default": "./dist/browser/esm/index.js"
            },
            "require": {
                "types": "./types/index.d.ts",
                "default": "./dist/browser/cjs/index.js"
            },
            "default": "./dist/browser/cjs/index.js"
        },
        "./api/resources/user": {
            "node": "./dist/node/api/resources/user.js",
            "import": {
                "types": "./types/api/resources/user/index.d.ts",
                "default": "./dist/browser/esm/api/resources/user.js"
            },
            "require": {
                "types": "./types/api/resources/user/index.d.ts",
                "default": "./dist/browser/cjs/api/resources/user.js"
            },
            "default": "./dist/browser/cjs/api/resources/user.js"
        },
        "./package.json": "./package.json"
    },
    "types": "./types/index.d.ts",
    "scripts": {
        "format": "biome format --write --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "format:check": "biome format --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint": "biome lint --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint:fix": "biome lint --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check": "biome check --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check:fix": "biome check --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "build": "pnpm compile && pnpm bundle",
        "compile": "tsc",
        "bundle": "node build.js",
        "test": "vitest",
        "test:unit": "vitest --project unit",
        "test:wire": "vitest --project wire"
    },
    "dependencies": {
        "lodash-es": "^4.17.21"
    },
    "devDependencies": {
        "webpack": "^5.105.4",
        "ts-loader": "^9.5.4",
        "vitest": "^4.1.1",
        "msw": "2.11.2",
        "@types/node": "^18.19.70",
        "typescript": "~5.9.3",
        "@biomejs/biome": "2.4.10",
        "esbuild": "~0.24.2"
    },
    "browser": {
        "fs": false,
        "os": false,
        "path": false,
        "stream": false,
        "crypto": false
    },
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=18.0.0"
    },
    "sideEffects": false
}
