{
    "name": "@fern/simple-api",
    "version": "0.0.1",
    "private": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/simple-api/fern.git"
    },
    "files": [
        "dist",
        "reference.md",
        "README.md",
        "LICENSE"
    ],
    "type": "commonjs",
    "sideEffects": false,
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.mjs",
    "browser": {
        "fs": false,
        "os": false,
        "path": false,
        "stream": false,
        "crypto": false
    },
    "types": "./dist/cjs/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/esm/index.d.mts",
                "default": "./dist/esm/index.mjs"
            },
            "require": {
                "types": "./dist/cjs/index.d.ts",
                "default": "./dist/cjs/index.js"
            },
            "default": "./dist/cjs/index.js"
        },
        "./user": {
            "import": {
                "types": "./dist/esm/api/resources/user/exports.d.mts",
                "default": "./dist/esm/api/resources/user/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/user/exports.d.ts",
                "default": "./dist/cjs/api/resources/user/exports.js"
            },
            "default": "./dist/cjs/api/resources/user/exports.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "format": "oxfmt --no-error-on-unmatched-pattern .",
        "format:check": "oxfmt --check --no-error-on-unmatched-pattern .",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "check": "pnpm format:check && pnpm lint",
        "check:fix": "pnpm format && pnpm lint:fix",
        "build": "pnpm build:cjs && pnpm build:esm",
        "build:cjs": "tsc --project ./tsconfig.cjs.json",
        "build:esm": "tsc --project ./tsconfig.esm.json && node scripts/rename-to-esm-files.js dist/esm",
        "test": "vitest",
        "test:unit": "vitest --project unit",
        "test:wire": "vitest --project wire"
    },
    "dependencies": {},
    "devDependencies": {
        "@types/node": "^18.19.70",
        "msw": "2.11.2",
        "oxfmt": "0.42.0",
        "oxlint": "1.57.0",
        "oxlint-tsgolint": "0.17.4",
        "ts-loader": "^9.5.4",
        "typescript": "~5.9.3",
        "vitest": "^4.1.1",
        "webpack": "^5.105.4"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "packageManager": "pnpm@10.33.0"
}
