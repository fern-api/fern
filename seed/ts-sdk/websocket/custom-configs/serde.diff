+                b: "b value",
+                raw_c: [
+                    {
+                        animal: {
+                            _type: "dog",
+                            value: true,
+                        },
+                    },
+                    {
+                        animal: {
+                            _type: "cat",
+                            raw_cat: 42,
+                        },
+                    },
+                ],
+                raw_d: false,
+                e: true,
+            },
+            parsed: {
+                a: "hello",
+                b: "b value",
+                c: [
+                    {
+                        animal: {
+                            type: "dog",
+                            value: true,
+                        },
+                    },
+                    {
+                        animal: {
