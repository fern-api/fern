+                    raw: {
+                        raw_foo: "foo",
+                        bar: "bar",
+                        // @ts-expect-error
+                        baz: "yoyo",
+                    },
+                    parsed: {
+                        foo: "foo",
+                        bar: "bar",
+                        // @ts-expect-error
+                        baz: "yoyo",
+                    },
+                    opts: {
+                        unrecognizedObjectKeys: "passthrough",
+                    },
+                },
