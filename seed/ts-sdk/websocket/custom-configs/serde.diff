+        object({
+            a: string(),
+            b: stringLiteral("b value"),
+            c: property(
+                "raw_c",
+                list(
+                    object({
+                        animal: union(discriminant("type", "_type"), {
+                            dog: object({ value: boolean() }),
+                            cat: object({ value: property("raw_cat", number()) }),
