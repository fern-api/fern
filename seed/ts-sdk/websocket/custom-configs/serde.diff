+                    foo: property("raw_foo", string()),
+                    bar: stringLiteral("bar"),
+                }),
+                {
+                    raw: {
+                        raw_foo: "foo",
+                        bar: "bar",
+                    },
+                    parsed: {
+                        foo: "foo",
+                        bar: "bar",
+                        // @ts-expect-error
+                        baz: "yoyo",
+                    },
+                    opts: {
+                        unrecognizedObjectKeys: "strip",
+                    },
+                },
+            );
+        });
+    });
+
+    describe("nullish properties", () => {
