{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "rules": {
    "dependencies": "error",
    "devDependencies": "error",
    "optionalPeerDependencies": "off",
    "unlisted": "off",
    "binaries": "off",
    "unresolved": "off",
    "files": "off",
    "duplicates": "off",
    "exports": "off",
    "types": "off",
    "nsExports": "off",
    "nsTypes": "off",
    "enumMembers": "off",
    "classMembers": "off"
  },
  "ignoreDependencies": [
    "@fern-api/*",
    "@fern-typescript/*",
    "@fern-fern/*",
    "vitest",
    "typescript",
    "@types/*",
    "ws",
    "pixelmatch",
    "@boundaryml/baml",
    "@trivago/prettier-plugin-sort-imports",
    "globals",
    "esbuild",
    "lodash-es",
    "execa",
    "tmp-promise",
    "strip-ansi",
    "express",
    "js-yaml",
    "node-fetch",
    "openapi-types",
    "gray-matter",
    "ajv",
    "ajv-formats",
    "yazl",
    "diff",
    "@open-rpc/meta-schema",
    "readable-stream"
  ],
  "ignore": ["node_modules/**", "**/dist/**", "**/lib/**", "**/generated/**", "**/docker/**", "**/__test__/**"]
}
