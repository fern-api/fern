{
  "name": "@fern-api/swift-model",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/fern-api/fern.git",
    "directory": "generators/swift/model"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "main": "lib/index.js",
  "source": "src/index.ts",
  "types": "lib/index.d.ts",
  "files": ["lib"],
  "scripts": {
    "clean": "rm -rf ./lib && rm -rf ./dist",
    "compile": "tsc",
    "compile:debug": "tsc --sourceMap",
    "depcheck": "knip --config ../../../knip.json --no-config-hints",
    "dist:cli": "node build.mjs",
    "dockerTagLatest": "docker build -f ./Dockerfile -t fernapi/fern-swift-model:latest ../../..",
    "podmanTagLatest": "podman build -f ./Dockerfile -t fernapi/fern-swift-model:latest ../../..",
    "publish:cli": "turbo run dist:cli --filter . && npm publish ./dist",
    "test": "vitest --passWithNoTests --run",
    "test:debug": "pnpm run test --inspect --no-file-parallelism",
    "test:update": "vitest --passWithNoTests --run -u"
  },
  "dependencies": {
    "@fern-api/base-generator": "workspace:*",
    "@fern-api/swift-base": "workspace:*",
    "@fern-fern/ir-sdk": "66.0.0",
    "lodash-es": "catalog:"
  },
  "devDependencies": {
    "@fern-api/configs": "workspace:*",
    "@fern-api/core-utils": "workspace:*",
    "@fern-api/fs-utils": "workspace:*",
    "@fern-api/swift-codegen": "workspace:*",
    "@fern-api/test-utils": "workspace:*",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
