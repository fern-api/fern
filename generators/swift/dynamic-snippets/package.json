{
  "name": "@fern-api/swift-dynamic-snippets",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/fern-api/fern.git",
    "directory": "generators/swift/dynamic-snippets"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "main": "lib/index.js",
  "source": "src/index.ts",
  "types": "lib/index.d.ts",
  "files": ["lib"],
  "scripts": {
    "clean": "rm -rf ./lib && rm -rf ./dist",
    "compile": "tsc",
    "compile:debug": "tsc --sourceMap",
    "depcheck": "knip --config ../../../knip.json --no-config-hints",
    "dist": "node build.mjs",
    "test": "vitest --passWithNoTests --run",
    "test:debug": "pnpm run test --inspect --no-file-parallelism",
    "test:update": "vitest --passWithNoTests --run -u"
  },
  "devDependencies": {
    "@fern-api/browser-compatible-base-generator": "workspace:*",
    "@fern-api/configs": "workspace:*",
    "@fern-api/core-utils": "workspace:*",
    "@fern-api/dynamic-ir-sdk": "66.1.0",
    "@fern-api/path-utils": "workspace:*",
    "@fern-api/swift-codegen": "workspace:*",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "lodash-es": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
