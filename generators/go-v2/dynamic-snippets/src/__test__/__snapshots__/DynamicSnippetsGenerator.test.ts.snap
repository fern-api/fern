"package example

import (
	context "context"

	acme "github.com/acme/acme-go"
	client "github.com/acme/acme-go/client"
	option "github.com/acme/acme-go/option"
)

func do() {
	client := client.NewClient(
		option.WithToken(
			"<YOUR_API_KEY>",
		),
	)
	request := &acme.ServiceGetMetadataRequest{
		Shallow: acme.Bool(
			false,
		),
		Tag: []*string{
			acme.String(
				"development",
			),
			acme.String(
				"public",
			),
		},
		APIVersion: "0.0.1",
	}
	client.Service.Getmetadata(
		context.TODO(),
		request,
	)
}
"
`;

