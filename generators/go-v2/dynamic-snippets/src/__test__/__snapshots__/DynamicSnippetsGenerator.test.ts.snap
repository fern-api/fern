		option.WithBaseURL(
			"https://api.example.com",
		),
	)
	request := &acme.NullableCreateUserRequest{
		Username: "john.doe",
		Tags: []string{
			"admin",
		},
		Metadata: &acme.Metadata{
			CreatedAt: acme.MustParseDateTime(
				"1980-01-01T00:00:00Z",
			),
			UpdatedAt: acme.MustParseDateTime(
				"1980-01-01T00:00:00Z",
			),
		},
	}
	client.Nullable.Createuser(
		context.TODO(),
		request,
	)
}
"
`;

