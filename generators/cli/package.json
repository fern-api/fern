{
  "name": "@fern-api/cli-generator",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/fern-api/fern.git",
    "directory": "generators/cli"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "main": "lib/index.js",
  "source": "src/index.ts",
  "types": "lib/index.d.ts",
  "files": ["lib"],
  "scripts": {
    "clean": "rm -rf ./lib && rm -rf ./dist",
    "compile": "tsc",
    "compile:debug": "tsc --sourceMap",
    "dist:cli": "node build.mjs",
    "dockerTagLatest": "docker build -f ./Dockerfile -t fernapi/fern-cli-generator:latest .",
    "dockerTagVersion": "turbo run dist:cli --filter . && docker build -f ./Dockerfile -t fernapi/fern-cli-generator:${0} .",
    "test": "vitest --passWithNoTests --run"
  },
  "devDependencies": {
    "@fern-api/base-generator": "workspace:*",
    "@fern-api/configs": "workspace:*",
    "@fern-api/core-utils": "workspace:*",
    "@fern-api/fs-utils": "workspace:*",
    "@fern-api/rust-model": "workspace:*",
    "@fern-fern/ir-sdk": "67.0.0",
    "@types/node": "catalog:",
    "commander": "^14.0.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
