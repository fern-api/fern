%% C4-style container view — fern-cli-sdk crate internals at the container level.

flowchart LR
    subgraph workspace["Cargo workspace: fern-cli-sdk"]
        direction TB
        subgraph lib["[lib] fern_cli_sdk"]
            direction TB
            SharedInfra["Shared infra<br/><i>auth, http, websocket,<br/>formatter, validate, error,<br/>logging, cli_args,<br/>custom_commands, completions, man</i>"]
            OpenAPIPath["src/openapi/<br/><i>parser, discovery, overlay,<br/>commands, executor, app, help</i>"]
            GraphQLPath["src/graphql/<br/><i>parser, discovery,<br/>commands, executor, app, help</i>"]
        end

        subgraph bins["[[bin]] targets — cli/&lt;name&gt;/"]
            direction TB
            UserCLIs["User-facing CLIs<br/><i>box, linear, square, bigcommerce,<br/>close, devin, assemblyai, paid, xero</i>"]
            FixtureCLIs["Test fixture CLIs<br/><i>openapi-fixture, graphql-fixture,<br/>multi-fixture, audience/overlay/base-path fixtures,<br/>billing-fixture</i>"]
        end

        PipelineCrate["crates/pipeline-fixture<br/><i>workspace member;<br/>cargo-dist release target</i>"]
    end

    OpenAPIPath -. "no shared abstractions" .- GraphQLPath
    SharedInfra --> OpenAPIPath
    SharedInfra --> GraphQLPath

    UserCLIs --> SharedInfra
    UserCLIs --> OpenAPIPath
    UserCLIs --> GraphQLPath
    FixtureCLIs --> SharedInfra
    FixtureCLIs --> OpenAPIPath
    FixtureCLIs --> GraphQLPath

    classDef lib fill:#e3f2fd,stroke:#1565c0
    classDef bin fill:#f3e5f5,stroke:#6a1b9a
    classDef isolated fill:#fff3e0,stroke:#e65100,stroke-width:2px
    class SharedInfra lib
    class OpenAPIPath,GraphQLPath isolated
    class UserCLIs,FixtureCLIs,PipelineCrate bin
