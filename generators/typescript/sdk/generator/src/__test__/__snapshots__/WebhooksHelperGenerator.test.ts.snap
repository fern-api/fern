exports[`WebhooksHelperGenerator > HMAC verification > writes HMAC class with multi-component payload format 1`] = `
"const TIMESTAMP_TOLERANCE_SECONDS = 300;

/**
 * Verify an HMAC webhook signature.
 *
 * Extract the signature from the "X-Signature" header and pass it as the signatureHeader parameter.
 * Extract the timestamp from the "X-Timestamp" header and pass it as the timestampHeader parameter.
 */
export class WebhooksHelper {
    public static async verifySignature(requestBody: string, signatureHeader: string, signatureKey: string, messageId: string, timestampHeader: string): Promise<boolean> {
        if (requestBody == null || signatureHeader == null || signatureKey == null) {
            throw new Error("Missing required parameters for webhook signature verification");
        }

        if (timestampHeader == null || timestampHeader === "") {
            throw new Error("Missing timestamp header 'X-Timestamp' for webhook signature verification");
        }

        const timestampValue = parseInt(timestampHeader, 10);
        if (Number.isNaN(timestampValue)) {
            throw new Error("Invalid timestamp format: expected unix seconds");
        }
        const timestampMs = timestampValue * 1000;

        if (Math.abs(Date.now() - timestampMs) > TIMESTAMP_TOLERANCE_SECONDS * 1000) {
            return false;
        }

        const payload = [messageId, timestampHeader, requestBody].join(".");

        const expected = webhookCrypto.computeHmacSignature({ payload: payload, secret: signatureKey, algorithm: "sha256", encoding: "hex" });

        return webhookCrypto.timingSafeEqual(signatureHeader, expected);
    }
}
"
`;

exports[`WebhooksHelperGenerator > HMAC verification > writes HMAC class with signature prefix 1`] = `
"const SIGNATURE_PREFIX = "sha256=";

/**
 * Verify an HMAC webhook signature.
 *
 * Extract the signature from the "X-Signature" header and pass it as the signatureHeader parameter.
 */
export class WebhooksHelper {
    public static async verifySignature(requestBody: string, signatureHeader: string, signatureKey: string): Promise<boolean> {
        if (requestBody == null || signatureHeader == null || signatureKey == null) {
            throw new Error("Missing required parameters for webhook signature verification");
        }

        const sig = signatureHeader.startsWith(SIGNATURE_PREFIX)
            ? signatureHeader.slice(SIGNATURE_PREFIX.length)
            : signatureHeader;

        const payload = requestBody;

        const expected = webhookCrypto.computeHmacSignature({ payload: payload, secret: signatureKey, algorithm: "sha256", encoding: "hex" });

        return webhookCrypto.timingSafeEqual(sig, expected);
    }
}
"
`;

