exports[`WebhooksHelperGenerator > asymmetric verification > writes asymmetric class with JWKS key source 1`] = `
"/**
 * Verify an asymmetric webhook signature.
 *
 * Extract the signature from the "X-Signature" header and pass it as the signatureHeader parameter.
 * Public keys are fetched from the JWKS endpoint at https://example.com/.well-known/jwks.json.
 */
export class WebhooksHelper {
    public static async verifySignature(requestBody: string, signatureHeader: string): Promise<boolean> {
        if (requestBody == null || signatureHeader == null) {
            throw new Error("Missing required parameters for webhook signature verification");
        }

        const payload = requestBody;

        const resolvedKey = await webhookCrypto.fetchJwks({ url: "https://example.com/.well-known/jwks.json" });

        return webhookCrypto.verifyAsymmetricSignature({ payload: payload, signature: signatureHeader, publicKey: resolvedKey, algorithm: "RSA_SHA256", encoding: "base64" });
    }
}
"
`;

exports[`WebhooksHelperGenerator > asymmetric verification > writes asymmetric class with JWKS key source and keyIdHeader 1`] = `
"/**
 * Verify an asymmetric webhook signature.
 *
 * Extract the signature from the "X-Signature" header and pass it as the signatureHeader parameter.
 * Public keys are fetched from the JWKS endpoint at https://example.com/.well-known/jwks.json.
 * Extract the key ID from the "X-Key-Id" header and pass it as the keyIdHeader parameter.
 */
export class WebhooksHelper {
    public static async verifySignature(requestBody: string, signatureHeader: string, keyIdHeader: string | undefined): Promise<boolean> {
        if (requestBody == null || signatureHeader == null) {
            throw new Error("Missing required parameters for webhook signature verification");
        }

        const payload = requestBody;

        const resolvedKey = await webhookCrypto.fetchJwks({ url: "https://example.com/.well-known/jwks.json", keyId: keyIdHeader });

        return webhookCrypto.verifyAsymmetricSignature({ payload: payload, signature: signatureHeader, publicKey: resolvedKey, algorithm: "RSA_SHA256", encoding: "base64" });
    }
}
"
`;

exports[`WebhooksHelperGenerator > asymmetric verification > writes asymmetric class with timestamp validation 1`] = `
"const TIMESTAMP_TOLERANCE_SECONDS = 300;
const SIGNATURE_PREFIX = "v1=";

/**
 * Verify an asymmetric webhook signature.
 *
 * Extract the signature from the "X-Signature" header and pass it as the signatureHeader parameter.
 * Extract the timestamp from the "X-Timestamp" header and pass it as the timestampHeader parameter.
 */
export class WebhooksHelper {
    public static async verifySignature(requestBody: string, signatureHeader: string, publicKey: string, timestampHeader: string): Promise<boolean> {
        if (requestBody == null || signatureHeader == null || publicKey == null) {
            throw new Error("Missing required parameters for webhook signature verification");
        }

        if (timestampHeader == null || timestampHeader === "") {
            throw new Error("Missing timestamp header 'X-Timestamp' for webhook signature verification");
        }

        const timestampValue = parseInt(timestampHeader, 10);
        if (Number.isNaN(timestampValue)) {
            throw new Error("Invalid timestamp format: expected unix seconds");
        }
        const timestampMs = timestampValue * 1000;

        if (Math.abs(Date.now() - timestampMs) > TIMESTAMP_TOLERANCE_SECONDS * 1000) {
            return false;
        }

        const sig = signatureHeader.startsWith(SIGNATURE_PREFIX)
            ? signatureHeader.slice(SIGNATURE_PREFIX.length)
            : signatureHeader;

        const payload = requestBody;

        return webhookCrypto.verifyAsymmetricSignature({ payload: payload, signature: sig, publicKey: publicKey, algorithm: "ECDSA_SHA256", encoding: "base64" });
    }
}
"
`;
