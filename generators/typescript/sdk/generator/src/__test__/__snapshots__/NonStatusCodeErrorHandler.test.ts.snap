// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`GeneratedNonStatusCodeErrorHandlerImpl > writes handleNonStatusCodeError function 1`] = `
"export function handleNonStatusCodeError(error: Fetcher.Error, rawResponse: RawResponse, method: string, path: string): never {
    switch (error.reason) {
        case "non-json": throw new ApiError({
            statusCode: error.statusCode,
            body: error.rawBody,
            rawResponse: rawResponse
        });
        case "body-is-null": throw new ApiError({
            statusCode: error.statusCode,
            rawResponse: rawResponse
        });
        case "timeout": throw new TimeoutError(\`Timeout exceeded when calling \${method} \${path}.\`, {
            cause: error.cause
        });
        case "unknown": throw new ApiError({
            message: error.message,
            rawResponse: rawResponse,
            cause: error.cause
        });
        default: throw new ApiError({
            message: "Unknown error",
            rawResponse: rawResponse
        });
    }
}
"
`;
