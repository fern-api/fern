{
  "name": "@fern-typescript/sdk-generator-cli",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/fern-api/fern.git",
    "directory": "generators/typescript/sdk/cli"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "main": "lib/index.js",
  "source": "src/index.ts",
  "types": "lib/index.d.ts",
  "files": ["lib"],
  "scripts": {
    "clean": "rm -rf ./lib && rm -rf ./dist",
    "compile": "tsc",
    "compile:debug": "tsc --sourceMap",
    "depcheck": "knip --config ../../../../knip.json --no-config-hints",
    "dist:cli": "node build.mjs",
    "dockerTagLatest": "docker build -f ./Dockerfile -t fernapi/fern-typescript-node-sdk:latest -t fernapi/fern-typescript-sdk:latest ../../../..",
    "podmanTagLatest": "podman build -f ./Dockerfile -t fernapi/fern-typescript-node-sdk:latest -t fernapi/fern-typescript-sdk:latest ../../../.."
  },
  "devDependencies": {
    "@fern-api/base-generator": "workspace:*",
    "@fern-api/configs": "workspace:*",
    "@fern-api/fs-utils": "workspace:*",
    "@fern-api/logger": "workspace:*",
    "@fern-api/typescript-ast": "workspace:*",
    "@fern-api/typescript-base": "workspace:*",
    "@fern-fern/ir-sdk": "^65.2.1",
    "@fern-typescript/abstract-generator-cli": "workspace:*",
    "@fern-typescript/commons": "workspace:*",
    "@fern-typescript/contexts": "workspace:*",
    "@fern-typescript/sdk-generator": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
