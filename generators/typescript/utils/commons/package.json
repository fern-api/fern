{
  "name": "@fern-typescript/commons",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/fern-api/fern.git",
    "directory": "generators/typescript/utils/commons"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "main": "lib/index.js",
  "source": "src/index.ts",
  "types": "lib/index.d.ts",
  "files": ["lib"],
  "scripts": {
    "clean": "rm -rf ./lib",
    "compile": "tsc",
    "compile:debug": "tsc --sourceMap",
    "depcheck": "knip --config ../../../../knip.json --no-config-hints",
    "test": "vitest --passWithNoTests --run",
    "test:debug": "pnpm run test --inspect --no-file-parallelism",
    "test:update": "vitest --passWithNoTests --run -u"
  },
  "dependencies": {
    "@fern-api/core-utils": "workspace:*",
    "@fern-api/fs-utils": "workspace:*",
    "@fern-api/logger": "workspace:*",
    "@fern-api/logging-execa": "workspace:*",
    "@fern-api/typescript-base": "workspace:*",
    "@fern-fern/ir-sdk": "^65.3.0",
    "decompress": "catalog:",
    "esutils": "catalog:",
    "eta": "^4.5.1",
    "glob": "catalog:",
    "immer": "^10.1.1",
    "lodash-es": "catalog:",
    "tmp-promise": "catalog:",
    "ts-morph": "catalog:",
    "url-join": "catalog:"
  },
  "devDependencies": {
    "@fern-api/configs": "workspace:*",
    "@types/decompress": "catalog:",
    "@types/esutils": "catalog:",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "@types/url-join": "4.0.1",
    "memfs": "catalog:",
    "package-json-type": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
