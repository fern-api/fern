{
  "name": "@fern-api/generator-migrations",
  "version": "0.0.0",
  "description": "Unified migration package for all Fern generator configurations",
  "keywords": ["fern", "generator", "migration"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fern-api/fern.git",
    "directory": "packages/generator-migrations"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/index.d.mts",
      "import": "./lib/index.mjs",
      "default": "./lib/index.mjs"
    }
  },
  "main": "lib/index.mjs",
  "source": "src/index.ts",
  "types": "lib/index.d.mts",
  "files": ["lib"],
  "scripts": {
    "clean": "rm -rf ./lib && rm -rf ./dist",
    "compile": "tsc",
    "compile:debug": "tsc --sourceMap",
    "depcheck": "knip --config ../../knip.json --no-config-hints",
    "dist": "node build.mjs",
    "test": "vitest --passWithNoTests --run",
    "test:debug": "pnpm run test --inspect --no-file-parallelism",
    "test:update": "vitest --passWithNoTests --run -u"
  },
  "dependencies": {},
  "devDependencies": {
    "@fern-api/configs": "workspace:*",
    "@fern-api/configuration": "workspace:*",
    "@fern-api/logger": "workspace:*",
    "@fern-api/migrations-base": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
