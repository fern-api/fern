{
  "name": "@fern-api/seed-cli",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/fern-api/fern.git",
    "directory": "packages/seed"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "main": "lib/index.js",
  "source": "src/index.ts",
  "types": "lib/index.d.ts",
  "files": ["lib"],
  "scripts": {
    "clean": "rm -rf ./lib && rm -rf ./dist",
    "compile": "tsc",
    "compile:debug": "tsc --sourceMap",
    "depcheck": "knip --config ../../knip.json --no-config-hints",
    "dist:cli": "node build.mjs",
    "env:prod": "env-cmd -r .env-cmdrc.cjs -e prod",
    "generate": "fern generate --local",
    "test": "vitest --run",
    "test:debug": "pnpm run test --inspect --no-file-parallelism",
    "test:update": "vitest --run -u"
  },
  "dependencies": {
    "@boundaryml/baml": "catalog:",
    "minimatch": "catalog:"
  },
  "devDependencies": {
    "@fern-api/api-workspace-commons": "workspace:*",
    "@fern-api/configs": "workspace:*",
    "@fern-api/configuration": "workspace:*",
    "@fern-api/core-utils": "workspace:*",
    "@fern-api/fs-utils": "workspace:*",
    "@fern-api/ir-generator": "workspace:*",
    "@fern-api/lazy-fern-workspace": "workspace:*",
    "@fern-api/local-workspace-runner": "workspace:*",
    "@fern-api/logger": "workspace:*",
    "@fern-api/logging-execa": "workspace:*",
    "@fern-api/source-resolver": "workspace:*",
    "@fern-api/login": "workspace:*",
    "@fern-api/task-context": "workspace:*",
    "@fern-api/workspace-loader": "workspace:*",
    "@fern-fern/fiddle-sdk": "catalog:",
    "@fern-fern/generators-sdk": "catalog:",
    "@types/js-yaml": "catalog:",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@types/yargs": "^17.0.28",
    "ajv": "8.18.0",
    "ajv-formats": "catalog:",
    "chalk": "catalog:",
    "console-table-printer": "catalog:",
    "find-up": "catalog:",
    "js-yaml": "catalog:",
    "lodash-es": "catalog:",
    "moment": "catalog:",
    "pretty-ms": "catalog:",
    "semver": "^7.6.2",
    "tmp-promise": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "yargs": "^17.4.1"
  }
}
