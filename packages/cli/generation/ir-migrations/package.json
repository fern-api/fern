{
  "name": "@fern-api/ir-migrations",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/fern-api/fern.git",
    "directory": "packages/cli/generation/ir-migrations"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "main": "lib/index.js",
  "source": "src/index.ts",
  "types": "lib/index.d.ts",
  "files": ["lib"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf ./lib && rm -f ./src/generated/generatorVersionMap*.ts",
    "compile": "pnpm generate:version-map && tsc",
    "compile:debug": "pnpm generate:version-map && tsc --sourceMap",
    "depcheck": "knip --config ../../../../knip.json --no-config-hints",
    "generate:version-map": "tsx scripts/generate-version-map.ts",
    "generate:version-map:force": "tsx scripts/generate-version-map.ts --force",
    "prebuild": "pnpm generate:version-map",
    "pretest": "pnpm generate:version-map",
    "test": "vitest --run",
    "test:debug": "pnpm run test --inspect --no-file-parallelism",
    "test:update": "vitest --run -u"
  },
  "dependencies": {
    "@fern-api/cli-source-resolver": "workspace:*",
    "@fern-api/configuration-loader": "workspace:*",
    "@fern-api/core-utils": "workspace:*",
    "@fern-api/fs-utils": "workspace:*",
    "@fern-api/ir-generator": "workspace:*",
    "@fern-api/ir-sdk": "workspace:*",
    "@fern-api/logger": "workspace:*",
    "@fern-api/semver-utils": "workspace:*",
    "@fern-api/task-context": "workspace:*",
    "@fern-api/workspace-loader": "workspace:*",
    "@fern-fern/ir-v53-sdk": "catalog:",
    "@fern-fern/ir-v54-sdk": "catalog:",
    "@fern-fern/ir-v55-sdk": "catalog:",
    "@fern-fern/ir-v56-sdk": "catalog:",
    "@fern-fern/ir-v57-sdk": "catalog:",
    "@fern-fern/ir-v58-sdk": "catalog:",
    "@fern-fern/ir-v59-sdk": "catalog:",
    "@fern-fern/ir-v60-sdk": "catalog:",
    "@fern-fern/ir-v61-sdk": "catalog:",
    "@fern-fern/ir-v62-sdk": "catalog:",
    "@fern-fern/ir-v63-sdk": "catalog:",
    "lodash-es": "catalog:"
  },
  "devDependencies": {
    "@fern-api/configs": "workspace:*",
    "@types/js-yaml": "catalog:",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "glob": "catalog:",
    "js-yaml": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
