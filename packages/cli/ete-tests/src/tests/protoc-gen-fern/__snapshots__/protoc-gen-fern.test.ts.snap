    "anduril.entitymanager.v1.Statement": {
      "name": {
        "typeId": "anduril.entitymanager.v1.Statement",
        "fernFilepath": {
          "allParts": [],
          "packagePath": [],
          "file": null
        },
        "name": "anduril.entitymanager.v1.Statement",
        "displayName": "Statement"
      },
      "shape": {
        "_type": "object",
        "properties": [
          {
            "name": "operation",
            "valueType": {
              "_type": "named",
              "fernFilepath": {
                "allParts": [],
                "packagePath": [],
                "file": null
              },
              "name": "anduril.entitymanager.v1.StatementOperation",
              "typeId": "anduril.entitymanager.v1.StatementOperation",
              "default": null,
