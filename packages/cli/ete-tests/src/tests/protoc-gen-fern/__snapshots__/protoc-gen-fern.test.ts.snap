                  "default": null,
                  "inline": false,
                  "displayName": "alpha"
                }
              }
            },
            "propertyAccess": null,
            "v2Examples": null,
            "availability": null,
            "docs": "The fraction of this color that should be applied to the pixel. That is,\\n the final pixel color is defined by the equation:\\n\\n \`pixel color = alpha * (this color) + (1.0 - alpha) * (background color)\`\\n\\n This means that a value of 1.0 corresponds to a solid color, whereas\\n a value of 0.0 corresponds to a completely transparent color. This\\n uses a wrapper message rather than a simple float scalar so that it is\\n possible to distinguish between a default value and the value being unset.\\n If omitted, this color object is rendered as a solid color\\n (as if the alpha value had been explicitly given a value of 1.0)."
          }
        ],
