{
  "name": "@fern-api/docs-preview",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/fern-api/fern.git",
    "directory": "packages/cli/docs-preview"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "main": "lib/index.js",
  "source": "src/index.ts",
  "types": "lib/index.d.ts",
  "files": ["lib"],
  "scripts": {
    "clean": "rm -rf ./lib",
    "compile": "tsc",
    "compile:debug": "tsc --sourceMap",
    "depcheck": "knip --config ../../../knip.json --no-config-hints",
    "test": "vitest --run",
    "test:debug": "pnpm run test --inspect --no-file-parallelism",
    "test:update": "vitest --run -u"
  },
  "dependencies": {
    "@fern-api/core-utils": "workspace:*",
    "@fern-api/docs-markdown-utils": "workspace:*",
    "@fern-api/docs-resolver": "workspace:*",
    "@fern-api/fdr-sdk": "1.1.23-d25ead8e05",
    "@fern-api/fs-utils": "workspace:*",
    "@fern-api/ir-sdk": "workspace:*",
    "@fern-api/ir-utils": "workspace:*",
    "@fern-api/logger": "workspace:*",
    "@fern-api/logging-execa": "workspace:*",
    "@fern-api/project-loader": "workspace:*",
    "@fern-api/register": "workspace:*",
    "@fern-api/task-context": "workspace:*",
    "chalk": "catalog:",
    "cli-progress": "catalog:",
    "cors": "catalog:",
    "decompress": "catalog:",
    "express": "catalog:",
    "gray-matter": "catalog:",
    "tmp-promise": "catalog:",
    "uuid": "catalog:",
    "watcher": "catalog:",
    "ws": "catalog:",
    "xml2js": "catalog:"
  },
  "devDependencies": {
    "@fern-api/configs": "workspace:*",
    "@types/cli-progress": "catalog:",
    "@types/cors": "catalog:",
    "@types/decompress": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/uuid": "^9.0.8",
    "@types/ws": "catalog:",
    "@types/xml2js": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
