{
  "name": "@fern-api/cli-migrations",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/fern-api/fern.git",
    "directory": "packages/cli/yaml/yaml-migrations"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "main": "lib/index.js",
  "source": "src/index.ts",
  "types": "lib/index.d.ts",
  "files": ["lib"],
  "scripts": {
    "clean": "rm -rf ./lib",
    "compile": "tsc",
    "compile:debug": "tsc --sourceMap",
    "depcheck": "knip --config ../../../knip.json --no-config-hints",
    "test": "vitest --run",
    "test:debug": "pnpm run test --inspect --no-file-parallelism",
    "test:update": "vitest --run -u"
  },
  "dependencies": {
    "@fern-api/configuration-loader": "workspace:*",
    "@fern-api/core-utils": "workspace:*",
    "@fern-api/fs-utils": "workspace:*",
    "@fern-api/semver-utils": "workspace:*",
    "@fern-api/task-context": "workspace:*",
    "@fern-fern/docs-config": "catalog:",
    "@fern-fern/legacy-docs-config": "catalog:",
    "chalk": "catalog:",
    "find-up": "catalog:",
    "glob": "catalog:",
    "inquirer": "^9.2.23",
    "js-yaml": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@fern-api/configs": "workspace:*",
    "@types/inquirer": "catalog:",
    "@types/js-yaml": "catalog:",
    "@types/node": "catalog:",
    "tmp-promise": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
