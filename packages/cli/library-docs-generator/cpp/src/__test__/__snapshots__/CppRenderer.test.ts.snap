is \`4\`. The corresponding output \`aggregate\` in thread0 is \`3\` (and is undefined in other threads).

\`\`\`cpp showLineNumbers={false}
#include <cub/cub.cuh>

__global__ void ExampleKernel(int *d_data, int valid_items)
{
