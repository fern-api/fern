{
  "name": "@fern-api/docs-resolver",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/fern-api/fern.git",
    "directory": "packages/cli/docs-resolver"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "main": "lib/index.js",
  "source": "src/index.ts",
  "types": "lib/index.d.ts",
  "files": ["lib"],
  "scripts": {
    "clean": "rm -rf ./lib",
    "compile": "tsc",
    "compile:debug": "tsc --sourceMap",
    "depcheck": "knip --config ../../../knip.json --no-config-hints",
    "test": "vitest --run src/utils/__test__",
    "test:debug": "vitest --run --inspect src/utils/__test__"
  },
  "dependencies": {
    "@fern-api/api-workspace-commons": "workspace:*",
    "@fern-api/cli-source-resolver": "workspace:*",
    "@fern-api/configuration": "workspace:*",
    "@fern-api/configuration-loader": "workspace:*",
    "@fern-api/core-utils": "workspace:*",
    "@fern-api/docs-markdown-utils": "workspace:*",
    "@fern-api/fdr-sdk": "catalog:",
    "@fern-api/fs-utils": "workspace:*",
    "@fern-api/graphql-to-fdr": "workspace:*",
    "@fern-api/ir-generator": "workspace:*",
    "@fern-api/ir-sdk": "workspace:*",
    "@fern-api/ir-utils": "workspace:*",
    "@fern-api/lazy-fern-workspace": "workspace:*",
    "@fern-api/project-loader": "workspace:*",
    "@fern-api/register": "workspace:*",
    "@fern-api/task-context": "workspace:*",
    "@fern-api/ui-core-utils": "catalog:",
    "@open-rpc/meta-schema": "catalog:",
    "@types/fast-levenshtein": "catalog:",
    "dayjs": "catalog:",
    "fast-levenshtein": "catalog:",
    "gray-matter": "catalog:",
    "heap-js": "catalog:",
    "js-yaml": "catalog:",
    "lodash-es": "catalog:",
    "openapi-types": "^12.1.3",
    "url-join": "catalog:"
  },
  "devDependencies": {
    "@fern-api/configs": "workspace:*",
    "@fern-api/workspace-loader": "workspace:*",
    "@types/js-yaml": "catalog:",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "@types/url-join": "^4.0.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
