{
  "name": "@fern-api/register",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/fern-api/fern.git",
    "directory": "packages/cli/register"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "main": "lib/index.js",
  "source": "src/index.ts",
  "types": "lib/index.d.ts",
  "files": ["lib"],
  "scripts": {
    "clean": "rm -rf ./lib",
    "compile": "tsc",
    "compile:debug": "tsc --sourceMap",
    "depcheck": "knip --config ../../../knip.json --no-config-hints",
    "test": "vitest --run --passWithNoTests",
    "test:debug": "pnpm run test --inspect --no-file-parallelism",
    "test:update": "vitest --run --passWithNoTests -u"
  },
  "dependencies": {
    "@fern-api/api-workspace-commons": "workspace:*",
    "@fern-api/auth": "workspace:*",
    "@fern-api/cli-source-resolver": "workspace:*",
    "@fern-api/configuration": "workspace:*",
    "@fern-api/core": "workspace:*",
    "@fern-api/core-utils": "workspace:*",
    "@fern-api/fdr-sdk": "catalog:",
    "@fern-api/fs-utils": "workspace:*",
    "@fern-api/ir-generator": "workspace:*",
    "@fern-api/ir-sdk": "workspace:*",
    "@fern-api/ir-utils": "workspace:*",
    "@fern-api/lazy-fern-workspace": "workspace:*",
    "@fern-api/logger": "workspace:*",
    "@fern-api/openapi-pruner": "workspace:*",
    "@fern-api/openapi-to-ir": "workspace:*",
    "@fern-api/task-context": "workspace:*",
    "@fern-api/v3-importer-commons": "workspace:*",
    "@fern-api/workspace-loader": "workspace:*",
    "@types/js-yaml": "catalog:",
    "js-yaml": "catalog:",
    "lodash-es": "catalog:",
    "openapi-types": "^12.1.3"
  },
  "devDependencies": {
    "@fern-api/configs": "workspace:*",
    "@fern-api/workspace-loader": "workspace:*",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
